# Copy to .env and fill in. The .env file is gitignored (never committed).

# Anthropic — meal/label photo scan + AI natural-language logging (server-side proxy)
ANTHROPIC_API_KEY=

# USDA FoodData Central — food search. Free key: https://fdc.nal.usda.gov/api-key-signup.html
# Leave blank to use the shared DEMO_KEY (works, but low rate limits).
USDA_FDC_API_KEY=

# Nutritionix free tier — natural-language logging fallback. https://developer.nutritionix.com
NUTRITIONIX_APP_ID=
NUTRITIONIX_APP_KEY=

# Supabase — accounts + cloud sync. From Dashboard → Project Settings → API.
# Public values (safe in the browser; protected by Row Level Security).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
